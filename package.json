{
  "name": "pencil-components",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/pencil-components/pencil-components.esm.js",
  "exports": {
    ".": {
      "import": "./dist/pencil-components/pencil-components.esm.js",
      "require": "./dist/pencil-components/pencil-components.cjs.js"
    },
    "./my-component": {
      "types": "./dist/components/my-component.d.ts",
      "import": "./dist/components/my-component.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ionic-team/stencil-component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "vitest --run",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.5",
    "@stencil/core": "^4.27.1",
    "@storybook/addon-essentials": "^8.6.3",
    "@storybook/blocks": "^8.6.3",
    "@storybook/test": "^8.6.3",
    "@storybook/web-components": "^8.6.3",
    "@storybook/web-components-vite": "^8.6.3",
    "@types/node": "^20.17.22",
    "lit": "^3.2.1",
    "storybook": "^8.6.3",
    "vitest": "^3.0.7"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "edgedriver",
      "esbuild",
      "geckodriver",
      "msw"
    ]
  },
  "dependencies": {
    "@vitest/browser": "^3.0.7",
    "unplugin-stencil": "^0.1.1",
    "webdriverio": "^9.10.1"
  }
}
